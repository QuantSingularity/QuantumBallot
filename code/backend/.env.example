# QuantumBallot Backend - Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_64_chars_long_replace_this
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_64_chars_long_replace_this

# ─── Encryption Keys for Blockchain ───────────────────────────────────────────
# 32-byte hex key (64 hex chars): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 16-byte hex IV  (32 hex chars): node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SECRET_KEY_IDENTIFIER=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SECRET_IV_IDENTIFIER=0123456789abcdef0123456789abcdef

# ─── Encryption Keys for Votes ────────────────────────────────────────────────
SECRET_KEY_VOTES=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
SECRET_IV_VOTES=fedcba9876543210fedcba9876543210

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
MAILER_SERVICE=gmail
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=your_email@example.com
MAILER_PASS=your_app_password_here

# ─── LevelDB ──────────────────────────────────────────────────────────────────
DB_PATH=./data/QuantumBallot_db
