{
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "../",
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "lib": ["ES2019"]
  },
  "include": ["src/**/*", "../blockchain/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "../blockchain/tests",
    "**/*.test.ts",
    "**/*.test.js"
  ]
}
