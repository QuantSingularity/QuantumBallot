# QuantumBallot Web Frontend Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3010
VITE_API_TIMEOUT=30000

# Firebase Configuration (required for image/audio storage)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Security - used for encrypting session tokens
VITE_SECRET_KEY_TOKEN=your_strong_random_secret_key_here

# Application Configuration
VITE_APP_NAME=QuantumBallot
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_2FA=true

# Development
VITE_DEBUG_MODE=false
