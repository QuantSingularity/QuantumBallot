# QuantumBallot Docker Environment Configuration
# Copy this file to .env and fill in the values before running docker-compose

# Build metadata
BUILD_DATE=
VCS_REF=
VERSION=latest

# Environment
ENVIRONMENT=development
NODE_ENV=production

# PostgreSQL
POSTGRES_DB=quantumballot
POSTGRES_USER=quantumballot

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# Frontend
VITE_API_URL=/api
CORS_ORIGIN=http://localhost:8080

# Logging
LOG_LEVEL=info
